{
  "name": "@velocity-bpa/n8n-nodes-oasys-gaming",
  "version": "1.0.0",
  "description": "n8n community node for Oasys Gaming blockchain operations including staking, bridging, and Verse L2 interactions",
  "license": "bsl-catalog",
  "homepage": "https://n8n.io",
  "author": {
    "name": "Velocity BPA",
    "email": "info@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velocity-bpa/n8n-nodes-oasys-gaming.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OasysGamingApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OasysGaming/OasysGaming.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "eslint": "^8.56.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "typescript": "~5.2.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}